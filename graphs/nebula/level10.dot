digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 10"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="TOCTOU flaw identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Listener ready"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Race exploit executed"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="flag10 token recovered"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag10 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag10/flag10.c"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="nc -l -p 18211"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/home/flag10/flag10 /tmp/link 127.0.0.1"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="nc -l -p 18211"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="su - flag10"];
}
