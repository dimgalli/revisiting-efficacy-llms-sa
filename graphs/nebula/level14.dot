digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 14"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Cipher behavior characterized"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Decryption routine prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="flag14 token recovered"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag14 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="/home/flag14/flag14 -e"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python - <<'PY'
enc=open('/home/flag14/token').read().strip()
print(''.join(chr(ord(c)-i) for i,c in enumerate(enc)))
PY"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag14/token | python /tmp/decrypt.py"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="su - flag14"];
}
