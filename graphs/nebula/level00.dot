digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 00"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node_ls_bin [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="/bin inspected"];
  node_ls_candidate_dir [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Candidate directory inspected"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="SUID binary found"];
  node1 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag00 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="find / -type f -executable -perm -4000 -user flag00 2>/dev/null"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="echo /bin/getflag | /bin/.../flag00"];
  start -> node_ls_bin [color="#555555", fontname="Helvetica", fontsize="10", label="ls -al /bin"];
  node_ls_bin -> node_ls_candidate_dir [color="#555555", fontname="Helvetica", fontsize="10", label="ls -al /bin/..."];
  node_ls_candidate_dir -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="ls -al /bin/.../flag00"];
}
