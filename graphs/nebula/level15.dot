digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 15"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="RPATH weakness identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Malicious libc prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag15 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="strace /home/flag15/flag15"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="gcc -shared -fPIC -o /var/tmp/flag15/libc.so.6 /tmp/libc.c"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/home/flag15/flag15"];
}
