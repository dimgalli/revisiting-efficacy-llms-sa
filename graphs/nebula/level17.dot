digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 17"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Deserialization flaw identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Malicious pickle payload prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Shell as flag17 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag17/flag17.py"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python /tmp/exploit17.py"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="nc -l -p 9999"];
}
