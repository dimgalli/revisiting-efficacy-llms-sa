digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 06"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="flag06 hash identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="flag06 password recovered"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag06 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="grep ^flag06: /etc/passwd"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="unshadow /etc/passwd /etc/shadow 2>/dev/null"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="su - flag06"];
}
