digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Nebula Level 18"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Login logic analyzed"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="File-descriptor exhaustion prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Logged in without password file"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution as flag18 obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /home/flag18/flag18.c"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="./a.out"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="./flag18 --init-file -d /dev/tty -v"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="shell"];
}
