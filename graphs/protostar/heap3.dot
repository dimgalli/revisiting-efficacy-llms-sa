digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Heap Three"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="winner() address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Heap unlink target chosen"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Fake chunk metadata prepared"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Free sequence primed for arbitrary write"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="winner() executed via heap metadata corruption"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/heap3 | grep \" winner$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/heap3"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"<fake_chunk_payload_a>\"'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/heap3 $(python -c 'print \"<fake_chunk_payload_a>\"') $(python -c 'print \"<fake_chunk_payload_b>\"') $(python -c 'print \"<trigger_payload_c>\"')"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/heap3 $(python -c 'print \"<fake_chunk_payload_a>\"') $(python -c 'print \"<fake_chunk_payload_b>\"') $(python -c 'print \"<trigger_payload_c>\"')"];
}
