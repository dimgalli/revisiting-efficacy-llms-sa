digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Net Zero"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Service banner parsed"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Requested integer converted to little endian"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Binary reply sent"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Correct reply accepted"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="nc <target-hostname-or-ip> 2999"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print struct.pack(\"<I\", <wanted>)'"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import re,struct,socket; s=socket.create_connection((\"<target-hostname-or-ip>\",2999)); data=s.recv(1024); n=int(re.search(r\"(\\d+)\", data).group(1)); s.sendall(struct.pack(\"<I\", n)); print s.recv(1024)'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import re,struct,socket; s=socket.create_connection((\"<target-hostname-or-ip>\",2999)); data=s.recv(1024); n=int(re.search(r\"(\\d+)\", data).group(1)); s.sendall(struct.pack(\"<I\", n)); print s.recv(1024)'"];
}
