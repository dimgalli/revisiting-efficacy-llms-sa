digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Net One"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Binary integer received"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Binary integer decoded"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="ASCII decimal reply sent"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Correct ASCII response accepted"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="nc <target-hostname-or-ip> 2998"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print struct.unpack(\"<I\", <four_bytes>)[0]'"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import socket,struct; s=socket.create_connection((\"<target-hostname-or-ip>\",2998)); raw=s.recv(4); n=struct.unpack(\"<I\", raw)[0]; s.sendall((str(n)+\"\\n\").encode()); print s.recv(1024)'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import socket,struct; s=socket.create_connection((\"<target-hostname-or-ip>\",2998)); raw=s.recv(4); n=struct.unpack(\"<I\", raw)[0]; s.sendall((str(n)+\"\\n\").encode()); print s.recv(1024)'"];
}
