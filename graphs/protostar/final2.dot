digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Final Two"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="FSRD request format understood"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Heap layout and destroy list behavior analyzed"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Path-moving bug converted into heap corruption primitive"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Remote heap metadata payload built"];
  node4 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Corrupted free sequence triggered"];
  node5 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Remote code execution obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import socket; s=socket.create_connection((\"<target-hostname-or-ip>\",2993)); s.sendall(\"FSRD/test\".ljust(128, \"A\")); print s.recv(1024)'"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/final2"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"FSRDROOTAAAA/BBBB\".ljust(128, \"A\")'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"<fsrd_heap_payload_sequence>\"' > /tmp/final2.in"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /tmp/final2.in | nc <target-hostname-or-ip> 2993"];
  node4 -> node5 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /tmp/final2.in | nc <target-hostname-or-ip> 2993"];
}
