digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Net Two"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Four integers received"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Wrapped 32-bit sum computed"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Sum packed as little endian"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Binary result sent"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Correct wrapped sum accepted"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="nc <target-hostname-or-ip> 2997"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 's=(a+b+c+d) & 0xffffffff; print s'"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print struct.pack(\"<I\", (<sum> & 0xffffffff))'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import socket,struct; s=socket.create_connection((\"<target-hostname-or-ip>\",2997)); raw=s.recv(16); nums=struct.unpack(\"<IIII\", raw); total=sum(nums) & 0xffffffff; s.sendall(struct.pack(\"<I\", total)); print s.recv(1024)'"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import socket,struct; s=socket.create_connection((\"<target-hostname-or-ip>\",2997)); raw=s.recv(16); nums=struct.unpack(\"<IIII\", raw); total=sum(nums) & 0xffffffff; s.sendall(struct.pack(\"<I\", total)); print s.recv(1024)'"];
}
