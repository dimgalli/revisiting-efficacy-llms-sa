digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Final Zero"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Remote service reachable"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Remote offset and crash primitive identified"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="toupper-safe payload prepared"];
  node3 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Return target for remote execution identified"];
  node4 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Remote code execution obtained"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="nc <target-hostname-or-ip> 2995"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"A\"*600' | nc <target-hostname-or-ip> 2995"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"<toupper_safe_payload>\"' > /tmp/final0.in"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="gdb -q /opt/protostar/bin/final0"];
  node3 -> node4 [color="#555555", fontname="Helvetica", fontsize="10", label="(cat /tmp/final0.in; cat) | nc <target-hostname-or-ip> 2995"];
}
